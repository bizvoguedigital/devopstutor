# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# JWT Security (backend)
JWT_SECRET_KEY=replace_with_a_long_random_secret_at_least_32_chars
# Optional: comma-separated previous secrets during key rotation
# JWT_PREVIOUS_SECRET_KEYS=old_key_1,old_key_2
# ENVIRONMENT=development

# Optional Groq Settings (defaults are provided in config.py)
# GROQ_MODEL=llama3-8b-8192
# GROQ_TEMPERATURE=0.7
# GROQ_MAX_TOKENS=2048

# Application Settings
# API_HOST=0.0.0.0
# API_PORT=8000
# API_RELOAD=true

# Database Settings
# DATABASE_URL=sqlite+aiosqlite:///./interview_data.db

# Speech Settings
# WHISPER_MODEL=base

# Interview Settings
# MAX_QUESTION_COUNT=10
# SESSION_TIMEOUT=3600