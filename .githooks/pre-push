#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "[githook:pre-push] Running pre-push checks..."

if [ -x "$REPO_ROOT/scripts/prepush-check.sh" ]; then
  "$REPO_ROOT/scripts/prepush-check.sh"
else
  bash "$REPO_ROOT/scripts/prepush-check.sh"
fi
