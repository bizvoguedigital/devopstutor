GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET_KEY=replace_with_a_long_random_secret_at_least_32_chars
# Optional comma-separated previous keys for rotation during cutover
# JWT_PREVIOUS_SECRET_KEYS=old_key_1,old_key_2
# Set ENVIRONMENT=production (or DEBUG=false) in production
# ENVIRONMENT=development
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
MONGODB_URI=mongodb://localhost:27017/ops_mentor_ai
MONGODB_DB_NAME=ops_mentor_ai
TTS_CACHE_ENABLED=true
TTS_CACHE_TTL_SECONDS=604800
TTS_CACHE_MAX_FILES=500
VOICE_AGENT_RUNTIME_ENABLED=false
VOICE_PROVIDER=livekit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=3600
LIVEKIT_ROOM_PREFIX=opsmentorai
